<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">

  <style type="text/css">
    * {
      box-sizing: border-box;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: #222;
      margin: 18px;
      font-size: 9pt;
    }

    h1, h2, h3, p {
      margin: 0;
      padding: 0;
    }

    .page-title {
      font-size: 13pt;
      font-weight: bold;
      color: #12344d;
      line-height: 1.3;
    }

    .logo {
      height: 42px;
      object-fit: contain;
    }

    .header-table,
    .info-table,
    .items-table,
    .comments-table,
    .footer-table {
      width: 100%;
      border-collapse: collapse;
    }

    .header-table td {
      border: 0;
      vertical-align: middle;
    }

    .top-spacing {
      height: 12px;
    }

    .os-box {
      text-align: right;
      font-size: 10pt;
      font-weight: bold;
      color: #12344d;
    }

    .section {
      margin-top: 14px;
      margin-bottom: 14px;
    }

    .section-title {
      background: #12344d;
      color: #fff;
      font-size: 9pt;
      font-weight: bold;
      padding: 8px 10px;
      border-radius: 6px 6px 0 0;
    }

    .info-wrapper {
      border: 1px solid #d9e1e7;
      border-top: 0;
      border-radius: 0 0 6px 6px;
      overflow: hidden;
      margin-bottom: 14px;
    }

    .info-table td {
      vertical-align: top;
      padding: 10px 12px;
      border-bottom: 1px solid #edf1f4;
    }

    .info-table tr:last-child td {
      border-bottom: 0;
    }

    .label {
      font-weight: bold;
      color: #12344d;
    }

    .info-line {
      margin-bottom: 6px;
      line-height: 1.45;
      font-size: 8.5pt;
    }

    .items-table {
      border: 1px solid #d9e1e7;
      border-radius: 6px;
      overflow: hidden;
    }

    .items-table th {
      background: #12344d;
      color: #fff;
      font-size: 8.5pt;
      font-weight: bold;
      padding: 8px 10px;
      text-align: left;
    }

    .items-table td {
      border-bottom: 1px solid #e9eef2;
      padding: 10px;
      vertical-align: middle;
    }

    .items-table tr:last-child td {
      border-bottom: 0;
    }

    .img-thumb {
      width: 100%;
      max-width: 170px;
      height: 120px;
      object-fit: cover;
      border: 1px solid #d8d8d8;
      border-radius: 8px;
      background: #f5f5f5;
      display: block;
      margin: 0 auto;
    }

    .img-large {
      width: 100%;
      max-width: 420px;
      height: 260px;
      object-fit: cover;
      border: 1px solid #d8d8d8;
      border-radius: 8px;
      background: #f5f5f5;
      display: block;
      margin: 0 auto;
    }

    .item-name {
      font-size: 9pt;
      font-weight: bold;
      color: #12344d;
      margin-bottom: 4px;
      line-height: 1.4;
    }

    .item-status {
      font-size: 8.5pt;
      line-height: 1.5;
      color: #333;
    }

    .status-bom {
      color: #1f7a1f;
      font-weight: bold;
    }

    .status-ruim {
      color: #b42318;
      font-weight: bold;
    }

    .status-faltante {
      color: #9a6700;
      font-weight: bold;
    }

    .detail-block {
      border: 1px solid #d9e1e7;
      border-radius: 8px;
      margin-bottom: 14px;
      overflow: hidden;
    }

    .detail-image {
      padding: 14px;
      text-align: center;
      background: #fafcfd;
      border-bottom: 1px solid #edf1f4;
    }

    .detail-content {
      padding: 12px 14px;
    }

    .comments-table th {
      background: #12344d;
      color: #fff;
      padding: 8px 10px;
      text-align: left;
      font-size: 8.5pt;
    }

    .comments-table td {
      border: 1px solid #d9e1e7;
      border-top: 0;
      padding: 12px;
      line-height: 1.6;
      font-size: 8.5pt;
    }

    .footer-table td {
      border: 0;
      border-top: 1px solid #d9e1e7;
      padding-top: 12px;
      font-size: 8pt;
      color: #444;
    }

    .footer-flex {
      width: 100%;
    }

    .footer-flex span {
      display: inline-block;
      width: 32%;
      vertical-align: top;
    }

    .page-break {
      page-break-before: always;
    }
  </style>
</head>

<body>
  <%
    function getStatus(avaliacao) {
      return avaliacao == 0 ? "Bom" : avaliacao == 1 ? "Ruim" : "Faltante";
    }

    function getStatusClass(avaliacao) {
      return avaliacao == 0 ? "status-bom" : avaliacao == 1 ? "status-ruim" : "status-faltante";
    }

    function getFoto(item) {
      return item && item.foto
        ? item.foto
        : 'https://triunfo.pe.gov.br/pm_tr430/wp-content/uploads/2018/03/sem-foto-300x300.jpg';
    }
  %>

  <!-- CABEÇALHO -->
  <table class="header-table">
    <tr>
      <td style="width: 75%;">
        <div class="page-title">REGISTRO FOTOGRÁFICO – COMPRESSOR - SUPERFRIO</div>
      </td>
      <td style="width: 25%; text-align: right;">
        <img src="https://superfrio.netlify.app/static/media/logo.a6ef6318.png" class="logo" alt="Logo">
      </td>
    </tr>
    <tr>
      <td class="top-spacing"></td>
      <td class="top-spacing"></td>
    </tr>
    <tr>
      <td></td>
      <td class="os-box">OS: <%= checklist.nos %></td>
    </tr>
  </table>

  <!-- INFORMAÇÕES GERAIS -->
  <div class="section">
    <div class="section-title">Informações Gerais</div>
    <div class="info-wrapper">
      <table class="info-table">
        <tr>
          <td style="width: 60%;">
            <div class="info-line"><span class="label">Cliente:</span> <%= checklist.idcliente.nome %></div>
            <div class="info-line"><span class="label">Cidade / UF:</span> <%= checklist.idcliente.cidade %> / <%= checklist.idcliente.uf %></div>
          </td>
          <td style="width: 40%;">
            <div class="info-line"><span class="label">Data Entrada:</span> <%= dataentrada %></div>
            <div class="info-line"><span class="label">Garantia?:</span> <%= checklist.garantia == false ? "Não" : "Sim" %></div>
          </td>
        </tr>
      </table>
    </div>
  </div>

  <!-- INFORMAÇÕES DO COMPRESSOR -->
  <div class="section">
    <div class="section-title">Informações do Compressor</div>
    <div class="info-wrapper">
      <table class="info-table">
        <tr>
          <td style="width: 60%;">
            <div class="info-line"><span class="label">Fabricante:</span> <%= checklist.idfabricante.nome %></div>
            <div class="info-line"><span class="label">Modelo:</span> <%= checklist.idcompressor.modelo %></div>
            <div class="info-line"><span class="label">Tensão:</span> <%= checklist.tensao %></div>
          </td>
          <td style="width: 40%;">
            <div class="info-line"><span class="label">N. Série:</span> <%= checklist.nserie %></div>
            <div class="info-line"><span class="label">N. Ativo:</span> <%= checklist.nativo %></div>
            <div class="info-line"><span class="label">Gás:</span> <%= checklist.gas %></div>
          </td>
        </tr>
      </table>
    </div>
  </div>

  <!-- TABELA INICIAL -->
  <div class="section">
    <table class="items-table">
      <tr>
        <th colspan="3">Avarias</th>
      </tr>

      <% for (var i = 0; i < 7 && i < itensLength; i++) { %>
        <tr>
          <td style="width: 28%; text-align: center;">
            <img src="<%= getFoto(checklistItens[i]) %>" class="img-thumb" alt="Imagem do item">
          </td>
          <td style="width: 32%;">
            <div class="item-name"><%= checklistItens[i].nomeitem %></div>
          </td>
          <td style="width: 40%;">
            <div class="item-status">
              <span class="<%= getStatusClass(checklistItens[i].avaliacao) %>"><%= getStatus(checklistItens[i].avaliacao) %></span>
              <%= checklistItens[i].comentario ? ' - ' + checklistItens[i].comentario : '' %>
            </div>
          </td>
        </tr>
      <% } %>
    </table>
  </div>

  <!-- DETALHES 7 a 18 -->
  <% if (itensLength > 7) { %>
    <div class="page-break"></div>

    <% for (var i = 7; i < 19 && i < itensLength; i++) { %>
      <div class="detail-block">
        <div class="detail-image">
          <img src="<%= getFoto(checklistItens[i]) %>" class="img-large" alt="Imagem do item">
        </div>
        <div class="detail-content">
          <div class="item-name"><%= checklistItens[i].nomeitem %></div>
          <div class="item-status">
            <span class="<%= getStatusClass(checklistItens[i].avaliacao) %>"><%= getStatus(checklistItens[i].avaliacao) %></span>
            <%= checklistItens[i].comentario ? ' - ' + checklistItens[i].comentario : '' %>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <!-- DETALHES 19 a 30 -->
  <% if (itensLength > 19) { %>
    <div class="page-break"></div>

    <% for (var i = 19; i < 31 && i < itensLength; i++) { %>
      <div class="detail-block">
        <div class="detail-image">
          <img src="<%= getFoto(checklistItens[i]) %>" class="img-large" alt="Imagem do item">
        </div>
        <div class="detail-content">
          <div class="item-name"><%= checklistItens[i].nomeitem %></div>
          <div class="item-status">
            <span class="<%= getStatusClass(checklistItens[i].avaliacao) %>"><%= getStatus(checklistItens[i].avaliacao) %></span>
            <%= checklistItens[i].comentario ? ' - ' + checklistItens[i].comentario : '' %>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <!-- DETALHES 31 em diante -->
  <% if (itensLength > 31) { %>
    <div class="page-break"></div>

    <% for (var i = 31; i < itensLength; i++) { %>
      <div class="detail-block">
        <div class="detail-image">
          <img src="<%= getFoto(checklistItens[i]) %>" class="img-large" alt="Imagem do item">
        </div>
        <div class="detail-content">
          <div class="item-name"><%= checklistItens[i].nomeitem %></div>
          <div class="item-status">
            <span class="<%= getStatusClass(checklistItens[i].avaliacao) %>"><%= getStatus(checklistItens[i].avaliacao) %></span>
            <%= checklistItens[i].comentario ? ' - ' + checklistItens[i].comentario : '' %>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <!-- COMENTÁRIOS -->
  <div class="section">
    <table class="comments-table">
      <tr>
        <th>Comentários</th>
      </tr>
      <tr>
        <td>
          <%= checklist.comentarios ? checklist.comentarios : 'Sem comentários.' %>
        </td>
      </tr>
    </table>
  </div>

  <!-- RODAPÉ -->
  <table class="footer-table">
    <tr>
      <td>
        <div class="footer-flex">
          <span><strong>Contato:</strong> (11) 4599-5239</span>
          <span><strong>Email:</strong> compressores@superfriosr.com.br</span>
          <span><strong>CNPJ:</strong> 18.553.796/0001-75</span>
        </div>
      </td>
    </tr>
  </table>

</body>
</html>